#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <MPU6050_light.h>
#include <Adafruit_MLX90614.h>
#include <MAX30105.h>
#include "spo2_algorithm.h"
#include <NimBLEDevice.h>
#include <HardwareSerial.h>
#include <TinyGPSPlus.h>

// ---------------- I2C PINS ESP32-C3 ----------------
#define SDA_PIN 8
#define SCL_PIN 9

// ---------------- GPS PINS ----------------
#define GPS_RX_PIN 20   // ESP32-C3 RX ← GPS TX
#define GPS_TX_PIN 21   // ESP32-C3 TX → GPS RX
#define GPS_BAUD 9600

// ---------------- OLED ----------------
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

// ---------------- SENSORS ----------------
MPU6050 mpu(Wire);
Adafruit_MLX90614 mlx;
MAX30105 particleSensor;

// ---------------- GPS ----------------
HardwareSerial gpsSerial(1);   // UART1
TinyGPSPlus gps;

// GPS data
double gpsLat = 0.0;
double gpsLng = 0.0;
bool gpsFixed = false;
int gpsSatellites = 0;

// ---------------- FALL DETECTION ----------------
// Uses JERK (sudden change in accel) — works regardless of wrist orientation
// Hand pointing down while still = NORMAL. Only actual falling = FREEFALL.
#define JERK_FALL_THRESHOLD  0.5   // G/sample — sudden DROP in accel starts freefall
#define IMPACT_THRESHOLD     2.5   // G — spike after freefall = confirmed fall
#define FALL_WINDOW_MS       700   // ms window to detect impact after freefall

// Smoothing — rolling average of last 5 readings
#define SMOOTH_SIZE 5
float accelHistory[SMOOTH_SIZE] = {1, 1, 1, 1, 1};
int   smoothIndex = 0;
float smoothedAccelG = 1.0;
float prevSmoothedAccelG = 1.0;  // to calculate jerk (change between readings)

bool inFreeFall = false;
bool fallDetected = false;
unsigned long freeFallTime = 0;
unsigned long fallAlertTime = 0;
const unsigned long FALL_ALERT_DURATION = 5000;

// ---------------- BLE ----------------
NimBLEServer* pServer = NULL;
NimBLECharacteristic* pCharacteristic = NULL;
#define SERVICE_UUID        "12345678-1234-1234-1234-1234567890ab"
#define CHARACTERISTIC_UUID "abcd1234-1234-1234-1234-abcdef123456"

// ---------------- TIMING ----------------
unsigned long lastSensorMillis  = 0;
unsigned long lastScreenSwitch  = 0;
unsigned long lastSampleMillis  = 0;
unsigned long lastFallCheck     = 0;

const int SENSOR_INTERVAL  = 200;
const int SCREEN_INTERVAL  = 3000;
const int SAMPLE_INTERVAL  = 40;
const int FALL_CHECK_INTERVAL = 50;  // check fall every 50ms for responsiveness

int screenIndex = 0;
// Screens: 0=MPU/Fall, 1=Temp, 2=Heart, 3=GPS

// ---------------- SENSOR DATA ----------------
float pitch = 0, roll = 0;
float accelX = 0, accelY = 0, accelZ = 0;
float totalAccelG = 1.0;
float tempObject = 0, tempAmbient = 0;

#define BUFFER_SIZE 50
uint32_t irBuffer[BUFFER_SIZE];
uint32_t redBuffer[BUFFER_SIZE];
int bufferIndex = 0;
int samplesCollected = 0;

int32_t spo2 = 0, heartRate = 0;
int8_t validSPO2 = 0, validHeartRate = 0;
bool fingerDetected = false;
const long FINGER_ON_THRESHOLD = 20000;

// ---------------- BLE SETUP ----------------
void setupBLE() {
  NimBLEDevice::init("SmartBand");
  NimBLEDevice::setPower(9);  // ESP32-C3 compatible power setting

  pServer = NimBLEDevice::createServer();

  NimBLEService *pService = pServer->createService(SERVICE_UUID);
  pCharacteristic = pService->createCharacteristic(
                      CHARACTERISTIC_UUID,
                      NIMBLE_PROPERTY::READ | NIMBLE_PROPERTY::NOTIFY
                    );
  pCharacteristic->setValue("Initializing...");
  pService->start();

  // Advertising — full setup for Android compatibility
  NimBLEAdvertising *pAdvertising = NimBLEDevice::getAdvertising();
  pAdvertising->addServiceUUID(SERVICE_UUID);
  pAdvertising->setScanResponse(true);
  pAdvertising->setMinPreferred(0x06);
  pAdvertising->setMaxPreferred(0x12);
  pAdvertising->setMinInterval(100);   // advertise frequently so phone finds it
  pAdvertising->setMaxInterval(200);
  pAdvertising->start();

  Serial.println("BLE Started - Advertising as: SmartBand");
}

// ---------------- STARTUP SCREEN ----------------
void startupScreen() {
  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);
  display.setTextSize(2);
  display.setCursor(0, 0);
  display.println("SMART BAND");
  display.setTextSize(1);
  display.setCursor(0, 25);
  display.println("Initializing...");
  display.display();
  delay(2000);
}

// ---------------- FALL DETECTION ----------------
void checkFallDetection() {
  // MPU6050_light returns accel in G
  accelX = mpu.getAccX();
  accelY = mpu.getAccY();
  accelZ = mpu.getAccZ();

  // Raw magnitude
  totalAccelG = sqrt(accelX*accelX + accelY*accelY + accelZ*accelZ);

  // --- Smoothing: rolling average of last 5 readings ---
  accelHistory[smoothIndex] = totalAccelG;
  smoothIndex = (smoothIndex + 1) % SMOOTH_SIZE;
  float sum = 0;
  for (int i = 0; i < SMOOTH_SIZE; i++) sum += accelHistory[i];
  prevSmoothedAccelG = smoothedAccelG;  // save previous before updating
  smoothedAccelG = sum / SMOOTH_SIZE;

  // --- JERK = how much accel changed since last reading ---
  // Normal wrist movement: small steady changes
  // Actual fall: sudden sharp DROP in accel (body goes weightless)
  float jerk = prevSmoothedAccelG - smoothedAccelG;  // positive = dropped

  // --- Freefall phase: detect sudden DROP in acceleration ---
  if (!inFreeFall && !fallDetected) {
    if (jerk > JERK_FALL_THRESHOLD && smoothedAccelG < 0.6) {
      // Sudden drop AND current accel is low — likely falling
      inFreeFall = true;
      freeFallTime = millis();
      Serial.print("FREEFALL triggered! jerk=");
      Serial.print(jerk);
      Serial.print(" accel=");
      Serial.println(smoothedAccelG);
    }
  }

  // --- Impact phase: sharp spike after freefall = confirmed fall ---
  if (inFreeFall) {
    unsigned long elapsed = millis() - freeFallTime;

    if (smoothedAccelG > IMPACT_THRESHOLD && elapsed < FALL_WINDOW_MS) {
      fallDetected = true;
      fallAlertTime = millis();
      inFreeFall = false;
      Serial.println(">>> FALL CONFIRMED! <<<");
      screenIndex = 0;
    }

    // No impact in time window — cancel (was not a real fall)
    if (elapsed > FALL_WINDOW_MS) {
      inFreeFall = false;
      Serial.println("No impact detected, reset.");
    }
  }

  // Clear fall alert after display duration
  if (fallDetected && (millis() - fallAlertTime > FALL_ALERT_DURATION)) {
    fallDetected = false;
  }
}

// ---------------- GPS UPDATE ----------------
void updateGPS() {
  // Feed all available GPS bytes into TinyGPSPlus
  while (gpsSerial.available() > 0) {
    gps.encode(gpsSerial.read());
  }

  if (gps.location.isValid()) {
    gpsFixed    = true;
    gpsLat      = gps.location.lat();
    gpsLng      = gps.location.lng();
    gpsSatellites = gps.satellites.value();
  } else {
    gpsFixed = false;
    gpsSatellites = gps.satellites.isValid() ? gps.satellites.value() : 0;
  }
}

// ---------------- SENSOR UPDATE ----------------
void updateSensors() {
  // MPU6050
  mpu.update();
  pitch = mpu.getAngleX();
  roll  = mpu.getAngleY();

  // MLX90614
  tempObject  = mlx.readObjectTempC();
  tempAmbient = mlx.readAmbientTempC();

  // MAX30102 - non-blocking
  particleSensor.check();
  if (particleSensor.available()) {
    long irValue  = particleSensor.getIR();
    long redValue = particleSensor.getRed();
    particleSensor.nextSample();

    if (irValue > FINGER_ON_THRESHOLD) {
      fingerDetected = true;

      if (millis() - lastSampleMillis >= SAMPLE_INTERVAL) {
        lastSampleMillis = millis();
        irBuffer[bufferIndex]  = irValue;
        redBuffer[bufferIndex] = redValue;
        bufferIndex = (bufferIndex + 1) % BUFFER_SIZE;

        if (samplesCollected < BUFFER_SIZE) {
          samplesCollected++;
        } else {
          maxim_heart_rate_and_oxygen_saturation(
            irBuffer, BUFFER_SIZE, redBuffer,
            &spo2, &validSPO2,
            &heartRate, &validHeartRate
          );
          // Reset buffer halfway so we keep getting fresh readings
          // instead of getting stuck with one bad calculation
          if (!validHeartRate || heartRate < 30 || heartRate > 220) {
            samplesCollected = BUFFER_SIZE / 2;
          }
        }
      }
    } else {
      fingerDetected   = false;
      bufferIndex      = 0;
      samplesCollected = 0;
      validSPO2        = 0;
      validHeartRate   = 0;
    }
  }
}

// ---------------- BLE SEND ----------------
void sendBLE() {
  String data = "";
  data += "P:"    + String(pitch, 1);
  data += ",R:"   + String(roll, 1);
  data += ",TO:"  + String(tempObject, 1);
  data += ",TA:"  + String(tempAmbient, 1);
  data += ",HR:"  + String(validHeartRate ? heartRate : 0);
  data += ",SPO2:"+ String(validSPO2 ? spo2 : 0);
  data += ",FALL:"+ String(fallDetected ? 1 : 0);
  data += ",LAT:" + String(gpsLat, 6);
  data += ",LNG:" + String(gpsLng, 6);
  data += ",FIX:" + String(gpsFixed ? 1 : 0);

  pCharacteristic->setValue(data.c_str());
  pCharacteristic->notify();
  Serial.println(data);
}

// ---------------- DISPLAY SCREENS ----------------

// Screen 0: Motion + Fall status — clean user-friendly view
void showMPU() {
  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);

  if (fallDetected) {
    // ---- FALL ALERT ----
    display.setTextSize(2);
    display.setCursor(15, 0);
    display.println("!! FALL !!");
    display.setTextSize(1);
    display.setCursor(20, 22);
    display.println("DETECTED!");
    display.setCursor(0, 38);
    display.println("SOS Sending...");
    display.setCursor(0, 52);
    if (gpsFixed) {
      display.print("LAT:"); display.println(gpsLat, 4);
    } else {
      display.println("GPS locating...");
    }
  } else if (inFreeFall) {
    // ---- Freefall in progress ----
    display.setTextSize(2);
    display.setCursor(10, 10);
    display.println("FALLING!");
    display.setTextSize(1);
    display.setCursor(25, 40);
    display.println("Detecting...");
  } else {
    // ---- Normal ----
    display.setTextSize(1);
    display.setCursor(0, 0);
    display.println("-- Motion Status --");
    // Big NORMAL text centered
    display.setTextSize(3);
    display.setCursor(8, 22);
    display.println("NORMAL");
  }
}

// Screen 1: Temperature
void showTemp() {
  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);
  display.setTextSize(2);
  display.setCursor(0, 0);
  display.println("TEMP C");
  display.setTextSize(1);
  display.setCursor(0, 20);
  display.print("Body  : "); display.print(tempObject, 1);  display.println(" C");
  display.print("Ambient: "); display.print(tempAmbient, 1); display.println(" C");

  // Simple fever indicator
  display.setCursor(0, 45);
  if (tempObject > 37.5) {
    display.println(">> FEVER ALERT <<");
  } else if (tempObject > 0) {
    display.println("Temp: Normal");
  }
}

// Screen 2: Heart rate & SpO2
void showHeart() {
  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);
  display.setTextSize(2);
  display.setCursor(0, 0);
  display.println("HEART");
  display.setTextSize(1);
  display.setCursor(0, 20);

  if (!fingerDetected) {
    display.println("Place Finger");
    display.setCursor(0, 32);
    display.println("on sensor...");
    display.setCursor(0, 48);
    display.println("Press firmly!");
  } else if (samplesCollected < BUFFER_SIZE) {
    display.println("Measuring...");
    display.setCursor(0, 32);
    // Progress bar
    int progress = (samplesCollected * 100) / BUFFER_SIZE;
    display.print("Progress: "); display.print(progress); display.println("%");
    display.setCursor(0, 44);
    display.println("Keep still...");
  } else {
    // Show results — handle -999 and invalid cases
    int bpm  = (validHeartRate && heartRate > 30 && heartRate < 220) ? heartRate : 0;
    int sp   = (validSPO2 && spo2 > 70 && spo2 <= 100) ? spo2 : 0;

    display.setTextSize(2);
    display.setCursor(0, 20);
    display.print("BPM:"); display.println(bpm > 0 ? String(bpm) : "--");
    display.setCursor(0, 40);
    display.print("SpO2:"); display.print(sp > 0 ? String(sp) : "--");
    if (sp > 0) display.println("%");
  }
}

// Screen 3: GPS
void showGPS() {
  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);
  display.setTextSize(1);
  display.setCursor(0, 0);
  display.println("--- GPS ---");

  if (gpsFixed) {
    display.setCursor(0, 12);
    display.print("LAT: "); display.println(gpsLat, 5);
    display.setCursor(0, 24);
    display.print("LNG: "); display.println(gpsLng, 5);
    display.setCursor(0, 36);
    display.print("SATS: "); display.println(gpsSatellites);
    display.setCursor(0, 50);
    display.println("Status: FIXED");
  } else {
    display.setCursor(0, 16);
    display.println("Searching...");
    display.setCursor(0, 30);
    display.print("Sats found: "); display.println(gpsSatellites);
    display.setCursor(0, 44);
    display.println("Point antenna");
    display.setCursor(0, 54);
    display.println("to open sky");
  }
}

void updateDisplay() {
  // Always override to fall screen if fall detected
  if (fallDetected) {
    showMPU();  // showMPU handles fall alert internally
  } else {
    if      (screenIndex == 0) showMPU();
    else if (screenIndex == 1) showTemp();
    else if (screenIndex == 2) showHeart();
    else                       showGPS();
  }
  display.display();
}

// ---------------- SETUP ----------------
void setup() {
  Serial.begin(115200);
  Serial.println("SmartBand v2 Starting...");

  // I2C
  Wire.begin(SDA_PIN, SCL_PIN);
  Wire.setClock(100000);

  // GPS Serial
  gpsSerial.begin(GPS_BAUD, SERIAL_8N1, GPS_RX_PIN, GPS_TX_PIN);
  Serial.println("GPS Serial started on UART1");

  // OLED
  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("OLED FAIL");
    while (1);
  }
  startupScreen();

  // MPU6050
  byte status = mpu.begin();
  if (status != 0) {
    Serial.println("MPU6050 FAIL");
  } else {
    Serial.println("MPU6050 OK - Calibrating (keep still)...");
    delay(1000);
    mpu.calcOffsets();
    Serial.println("MPU6050 Ready");
  }

  // MLX90614
  if (!mlx.begin()) {
    Serial.println("MLX90614 FAIL");
  } else {
    Serial.println("MLX90614 OK");
  }

  // MAX30102
  if (!particleSensor.begin(Wire, I2C_SPEED_STANDARD)) {
    Serial.println("MAX30102 FAIL");
  } else {
    Serial.println("MAX30102 OK");
    particleSensor.setup(0x1F, 4, 2, 100, 411, 4096);
    particleSensor.setPulseAmplitudeRed(0x1F);
    particleSensor.setPulseAmplitudeIR(0x1F);
    particleSensor.setPulseAmplitudeGreen(0);
  }

  // Init buffers
  for (int i = 0; i < BUFFER_SIZE; i++) {
    irBuffer[i] = 0;
    redBuffer[i] = 0;
  }

  // BLE
  setupBLE();
  Serial.println("Setup Complete - 4 screens: Motion|Temp|Heart|GPS");
}

// ---------------- LOOP ----------------
void loop() {
  unsigned long now = millis();

  // Fall detection — checked frequently (every 50ms)
  if (now - lastFallCheck >= FALL_CHECK_INTERVAL) {
    lastFallCheck = now;
    mpu.update();  // keep MPU updated for fall check
    checkFallDetection();
  }

  // Full sensor update + BLE
  if (now - lastSensorMillis >= SENSOR_INTERVAL) {
    lastSensorMillis = now;
    updateSensors();
    updateGPS();
    sendBLE();
  }

  // Switch screen (only when no fall alert)
  if (!fallDetected && (now - lastScreenSwitch >= SCREEN_INTERVAL)) {
    lastScreenSwitch = now;
    screenIndex = (screenIndex + 1) % 4;  // 4 screens now
  }

  // Always update display
  updateDisplay();
}